APP_ENV=local
APP_NAME=Review Robin Web
DEBUG=true

# Local-only authentication fallback. Never enable in deployed environments.
ALLOW_FAKE_AUTH=true
FAKE_AUTH_EMAIL=operator@example.edu
FAKE_AUTH_NAME=Local Operator

# Segment 16A Option C strict-allowlist bootstrap. Comma-separated
# emails seeded once into ``users.is_operator`` / ``users.is_sys_admin``
# on first sign-in. After that the persisted columns are
# authoritative; removing an email here does NOT auto-revoke.
# Revocation goes through the 16A PR 6 workspace user-list UI.
#
# Locally these are inert because ALLOW_FAKE_AUTH=true is honoured
# (the fake user picks up FAKE_AUTH_OPERATOR / FAKE_AUTH_SYS_ADMIN
# instead, both default-True in app/config.py). They matter once
# the dev slot deploys with ALLOW_FAKE_AUTH=false — the App Service
# config needs the same values set there for real Entra sign-ins
# to bootstrap correctly.
OPERATOR_EMAILS=philoyhc@gmail.com
SYS_ADMIN_EMAILS=philoyhc@gmail.com

# Database. Defaults to a local SQLite file when unset.
# Local Postgres setup is intentionally deferred (see docs/database.md and
# guide/segment_05A.md §3.5). To run against any local Postgres you've set up
# yourself, uncomment and edit the line below:
# DATABASE_URL=postgresql+psycopg://rrw_app:CHANGE_ME@localhost:5432/rrw
