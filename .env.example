APP_ENV=local
APP_NAME=Review Robin Web
DEBUG=true

# Local-only authentication fallback. Never enable in deployed environments.
ALLOW_FAKE_AUTH=true
FAKE_AUTH_EMAIL=operator@example.edu
FAKE_AUTH_NAME=Local Operator

# Database. Defaults to a local SQLite file when unset.
# Local Postgres setup is intentionally deferred (see docs/database.md and
# guide/segment_05A.md §3.5). To run against any local Postgres you've set up
# yourself, uncomment and edit the line below:
# DATABASE_URL=postgresql+psycopg://rrw_app:CHANGE_ME@localhost:5432/rrw
